---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
sidebar:
  order: 2
---

<StarlightPage frontmatter={{ title: 'My HTML Page' , tableOfContents: false }}>

  <div class="full-page">
  <h1>Full Width Custom HTML</h1>

  <section class="hero">
    <h2>My Custom Section</h2>
    <p>
      This page uses normal HTML and local CSS classes inside an `.astro` file.
      The TOC is disabled, so the content can use the available width.
    </p>
  </section>

  <section class="grid">
    <div class="card">
      <h3>Card One</h3>
      <p>Local CSS styling.</p>
    </div>

    <div class="card">
      <h3>Card Two</h3>
      <p>Wide layout content.</p>
    </div>
  </section>
</div>

</StarlightPage>

<style>
  /*
    This controls Starlight's main content width
    for this page.
  */
  :global(.sl-container) {
    max-width: 100%;
  }

  .full-page {
    width: 100%;
    max-width: 100%;
    padding: 2rem;
  }

  .hero {
    background: #f4f7ff;
    border: 1px solid #d8e2ff;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .hero h2 {
    margin-top: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .card {
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 1.5rem;
    background: white;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .full-page {
      padding: 1rem;
    }
  }
</style>